{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "$comment": "Provisional contractor shell grants: .ai/shared/references/contractor-provisional-shell-allowlist.json — no Bash(git *) or Bash(gh *) until owner approves git/gh in contract.json approved_capabilities[] and Phase 5B verifies tools.json.",
  "agent": "splunky",
  "includeGitInstructions": true,
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git fetch*)",
      "Bash(git branch*)",
      "Bash(git remote*)",
      "Bash(git rev-parse*)",
      "Bash(git show*)",
      "Bash(git ls-remote*)",
      "Bash(git worktree list*)",
      "Bash(git worktree add *)",
      "Bash(git checkout proj/splunk-clone/*)",
      "Bash(git switch proj/splunk-clone/*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push -u origin proj/splunk-clone/*)",
      "Bash(git push origin proj/splunk-clone/*)",
      "Bash(gh pr view*)",
      "Bash(gh pr create*)",
      "Bash(gh pr diff*)",
      "Bash(gh issue view*)",
      "Bash(gh issue create*)",
      "Bash(gh workflow view*)",
      "Bash(gh auth status*)",
      "Bash(scripts/agent-report *)",
      "Bash(scripts/agent-verify-caps *)",
      "Bash(scripts/agent-contract-pr-review *)",
      "Bash(scripts/agent-init*)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Skill"
    ]
  },
  "hooks": {}
}

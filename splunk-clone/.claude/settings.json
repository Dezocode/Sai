{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "agent": "splunky",
  "includeGitInstructions": true,
  "permissions": {
    "$comment_provisional_gh": "Provisional: no blanket gh wildcard in allow — see .ai/shared/references/contractor-claude-gh-permissions.md",
    "allow": [
      "Bash(git *)",
      "Bash(gh auth status*)",
      "Bash(gh repo view*)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr checks*)",
      "Bash(gh pr create*)",
      "Bash(gh run list*)",
      "Bash(gh run view*)",
      "Bash(gh workflow view*)",
      "Bash(gh status*)",
      "Bash(scripts/agent-report *)",
      "Bash(scripts/agent-contract-pr-review *)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Skill"
    ]
  },
  "hooks": {}
}

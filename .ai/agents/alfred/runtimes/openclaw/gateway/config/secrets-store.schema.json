{
  "$schema": "openclaw-secrets-store-v1",
  "$comment": "VPS-only secret structure — NO values in Git. PR #45 controlling schema.",
  "contract_id": "20260722-openclaw-dashboard-dezocode",
  "security_doctrine": "openclaw-dashboard/docs/secrets-security.md",
  "vps_paths": {
    "env_file": {
      "path": "/etc/openclaw/sai.env",
      "mode": "0600",
      "owner": "root",
      "group": "openclaw"
    },
    "openclaw_config": {
      "path": "~/.openclaw/openclaw.json",
      "rule": "env_var_references_only",
      "forbidden": ["literal_bot_tokens", "literal_oauth_secrets"]
    },
    "session_store": {
      "path": "~/.openclaw/sessions/",
      "rule": "redacted_transcripts_only"
    },
    "composio_cache": {
      "path": "/var/lib/openclaw/composio/",
      "mode": "0700"
    }
  },
  "env_registry": [
    {"name": "OPENCLAW_GATEWAY_TOKEN", "provider": "openclaw", "required": true},
    {"name": "TELEGRAM_BOT_TOKEN", "provider": "telegram", "required": true},
    {"name": "SLACK_APP_TOKEN", "provider": "slack", "required": true},
    {"name": "SLACK_BOT_TOKEN", "provider": "slack", "required": true},
    {"name": "COMPOSIO_API_KEY", "provider": "composio", "required": true},
    {"name": "GITHUB_OAUTH_CLIENT_ID", "provider": "github", "required": true},
    {"name": "GITHUB_OAUTH_CLIENT_SECRET", "provider": "github", "required": true, "client_visible": false},
    {"name": "SAI_SLACK_BOT_TOKEN", "provider": "sai", "required": false, "ci_also": true},
    {"name": "TAILSCALE_AUTH_KEY", "provider": "tailscale", "required": false}
  ],
  "dashboard_rules": {
    "display": "masked_only",
    "export_secrets": false,
    "copy_values": false,
    "log_values": false
  },
  "git_forbidden_globs": [
    ".env",
    ".env.*",
    "**/sai.env",
    "**/openclaw.json.local",
    "**/*credentials*.json",
    "**/*.pem"
  ]
}

{
  "title": "Provisional contractor Claude Code Bash allowlist",
  "icm_layer": 3,
  "policy": "Replace Bash(git *) and Bash(gh *) wildcards for registry status provisional until contract.json approved_capabilities[] records owner approval for git/gh shell and ONBOARDING Phase 5B verifies runtimes/<suite>/tools.json.",
  "branch_scope_example": "proj/splunk-clone/ctr-code-splunky/*",
  "bash_allow_patterns": [
    "Bash(git status*)",
    "Bash(git diff*)",
    "Bash(git log*)",
    "Bash(git fetch*)",
    "Bash(git branch)",
    "Bash(git branch -a*)",
    "Bash(git branch -r*)",
    "Bash(git branch -v*)",
    "Bash(git branch --list*)",
    "Bash(git branch --show-current*)",
    "Bash(git branch --contains*)",
    "Bash(git branch --merged*)",
    "Bash(git branch --no-merged*)",
    "Bash(git branch --points-at*)",
    "Bash(git branch --format*)",
    "Bash(git branch --sort*)",
    "Bash(git branch proj/splunk-clone/*)",
    "Bash(git remote*)",
    "Bash(git rev-parse*)",
    "Bash(git show*)",
    "Bash(git ls-remote*)",
    "Bash(git worktree list*)",
    "Bash(git worktree add *)",
    "Bash(git checkout proj/splunk-clone/*)",
    "Bash(git switch proj/splunk-clone/*)",
    "Bash(git add *)",
    "Bash(git commit *)",
    "Bash(git push -u origin proj/splunk-clone/*)",
    "Bash(git push origin proj/splunk-clone/*)",
    "Bash(gh pr view*)",
    "Bash(gh pr create*)",
    "Bash(gh pr diff*)",
    "Bash(gh issue view*)",
    "Bash(gh issue create*)",
    "Bash(gh workflow view*)",
    "Bash(gh auth status*)",
    "Bash(scripts/agent-report *)",
    "Bash(scripts/agent-verify-caps *)",
    "Bash(scripts/agent-contract-pr-review *)",
    "Bash(scripts/agent-init*)"
  ],
  "hard_review_gates_not_in_allowlist": [
    "git push --force",
    "git reset --hard",
    "git clean -fdx",
    "git branch -D",
    "git branch -d",
    "git branch --delete",
    "git branch -m",
    "git branch -M",
    "gh pr merge",
    "gh pr close",
    "gh repo delete",
    "gh release create"
  ],
  "expansion": "After owner approval in contract.json approved_capabilities[], amend this list via contract amendment and re-run scripts/agent-verify-caps; never restore Bash(git *) or Bash(gh *) for provisional contractors."
}

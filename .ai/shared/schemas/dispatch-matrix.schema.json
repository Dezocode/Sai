{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Dezocode/Sai/.ai/shared/schemas/dispatch-matrix.schema.json",
  "title": "SAI dispatch matrix",
  "description": "Slack + GitHub routing for every registered agent; validated by scripts/verify-dispatcher-matrix.",
  "type": "object",
  "required": ["matrix_version", "agents"],
  "additionalProperties": true,
  "properties": {
    "matrix_version": { "type": "string", "minLength": 1 },
    "contract_ref": { "type": "string" },
    "channels": { "type": "object" },
    "repositories": { "type": "object" },
    "agents": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["name", "folder", "slack", "github"],
        "properties": {
          "name": { "type": "string" },
          "folder": { "type": "string", "pattern": "^\\.ai/agents/" },
          "primary_runtime": { "type": "string" },
          "dispatcher": { "type": "boolean" },
          "slack": {
            "type": "object",
            "required": ["mention", "channels"],
            "properties": {
              "mention": { "type": "string" },
              "channels": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string" }
              },
              "trigger": { "type": "string" },
              "report_template": { "type": "string" }
            }
          },
          "github": {
            "type": "object",
            "required": ["repos", "triggers"],
            "properties": {
              "repos": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string" }
              },
              "triggers": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string" }
              },
              "ci_workflow": { "type": "string" },
              "entry": { "type": "string" },
              "branch_prefix": { "type": "string" }
            }
          },
          "subagent_cli": { "type": "object" }
        }
      }
    }
  }
}

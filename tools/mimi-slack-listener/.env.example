# Copy to /etc/mimi-listener.env on the listener host (mode 0600, root or
# service user only). NEVER commit real values — this repo's reporting
# policy forbids tokens in git/Slack/logs.
SLACK_BOT_TOKEN=xoxb-REPLACE-ME
SLACK_APP_TOKEN=xapp-REPLACE-ME
# Absolute path to the monaecode/Sai clone the agent runs in.
MIMI_REPO=/home/monaecode/Sai
# Claude Code binary (current version with agent support).
CLAUDE_BIN=/usr/local/bin/claude
# REQUIRED (fail-closed, Saul P1): comma-separated channel-ID allowlist.
# The listener refuses to start if this is empty. #agentupdates shown.
MIMI_ALLOWED_CHANNELS=C0BH15HDN2Z
# Subagent the dispatch runs as (explicit selection, Saul P1).
MIMI_DISPATCH_AGENT=mimi-dispatcher
# Subprocess timeout for one dispatch (seconds).
MIMI_TIMEOUT_S=600

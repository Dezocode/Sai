#!/usr/bin/env bash
# agent-automation-spec — generate the default automation profile for an SAI
# agent (Phase 7 of .ai/INITIALIZE.md). Default --suite cursor emits a Cursor
# Automations UI profile; --suite claude emits a Claude Code-native profile.
#
# Every agent that completes initialization offers this profile to its
# principal (dezocode or monaecode) so automation agents can be set up
# easily and consistently for ANY role. The purpose section is
# role-specific; the SAI protocol block is identical for every agent, so
# all automations follow the same Slack, GitHub, and CI protocols.
#
# The output matches the real Cursor Automations UI: Name, Active toggle,
# repository selector, Triggers (Scheduled), Agent Instructions, model
# selector, and Tools (Slack / GitHub / MCP).
#
# Usage:
#   agent-automation-spec --agent-id ID --agent-name NAME --role-title TITLE \
#                         --principal HUMAN --purpose "ONE-PARAGRAPH PURPOSE" \
#                         [--repo OWNER/REPO] [--branch BRANCH]
#                         [--tools-file .ai/agents/<slug>/tools.json]
#                         [--folder-name slug]  # canonical .ai/agents/<slug>/ path
#                         [--schedule "daily 09:00 America/Chicago"]
#                         [--suite cursor|claude]
#                         [--out PATH | --stdout]
set -euo pipefail

AGENT_ID="${SAI_AGENT_ID:-}"
AGENT_NAME=""
ROLE_TITLE=""
PRINCIPAL=""
PURPOSE=""
REPO="Dezocode/Sai"
BRANCH="main"
SCHEDULE="daily at 09:00 (principal's timezone; proposed)"
SUITE="cursor"
TOOLS_FILE=""
FOLDER_NAME=""
OUT=""
TO_STDOUT=0

while [ $# -gt 0 ]; do
  case $1 in
    --agent-id)   AGENT_ID=$2; shift 2;;
    --agent-name) AGENT_NAME=$2; shift 2;;
    --role-title) ROLE_TITLE=$2; shift 2;;
    --principal)  PRINCIPAL=$2; shift 2;;
    --purpose)    PURPOSE=$2; shift 2;;
    --repo)       REPO=$2; shift 2;;
    --branch)     BRANCH=$2; shift 2;;
    --tools-file) TOOLS_FILE=$2; shift 2;;
    --folder-name) FOLDER_NAME=$2; shift 2;;
    --schedule)   SCHEDULE=$2; shift 2;;
    --suite)      SUITE=$2; shift 2;;
    --out)        OUT=$2; shift 2;;
    --stdout)     TO_STDOUT=1; shift;;
    *) echo "agent-automation-spec: unknown option $1" >&2; exit 2;;
  esac
done

[ -n "$AGENT_ID" ]  || { echo "agent-automation-spec: --agent-id (or SAI_AGENT_ID) is required" >&2; exit 1; }
[ -n "$PRINCIPAL" ] || { echo "agent-automation-spec: --principal is required" >&2; exit 1; }
[ -n "$AGENT_NAME" ] || AGENT_NAME="(name pending Phase 5 grant)"
[ -n "$ROLE_TITLE" ] || ROLE_TITLE="(role title pending Phase 5 grant)"
[ -n "$PURPOSE" ]    || PURPOSE="Protocol upkeep for ${REPO}: keep the SAI reporting queue flushed, verify audit and semantic compliance, verify Drive sync status, and report to #agentupdates. (Default purpose — replace once the principal confirms a role-specific purpose.)"

case "$SUITE" in
  cursor|claude) ;;
  *) echo "agent-automation-spec: --suite must be cursor or claude (got: $SUITE)" >&2; exit 2;;
esac

REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
# shellcheck source=scripts/lib/agent-path-guards.sh
. "$SCRIPT_DIR/lib/agent-path-guards.sh"
slugify() { printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g;s/--*/-/g;s/^-//;s/-$//'; }

derive_folder_from_path() {
  local p=$1
  case "$p" in
    *"/.ai/agents/"*)
      local rest=${p#*"/.ai/agents/"}
      local slug=${rest%%/*}
      if [ -n "$slug" ]; then
        printf '%s' "$slug"
      fi
      ;;
  esac
}

FOLDER_SLUG="$FOLDER_NAME"
if [ -z "$FOLDER_SLUG" ] && [ -n "$TOOLS_FILE" ]; then
  FOLDER_SLUG=$(derive_folder_from_path "$TOOLS_FILE")
fi
if [ -z "$FOLDER_SLUG" ] && [ -n "$OUT" ]; then
  FOLDER_SLUG=$(derive_folder_from_path "$OUT")
fi
if [ -z "$FOLDER_SLUG" ]; then
  if printf '%s' "$AGENT_NAME" | grep -q 'pending'; then
    FOLDER_SLUG="$AGENT_ID"
  else
    FOLDER_SLUG=$(slugify "$AGENT_NAME")
  fi
fi
guard_slug folder-name "$FOLDER_SLUG"

[ -n "$OUT" ] || OUT="$REPO_ROOT/.ai/agents/automation-specs/${AGENT_ID}.md"
TODAY=$(date -u +%Y-%m-%d)

# Build Tools section from verified capabilities in tools.json (Phase 5B).
TOOLS_SECTION=""
if [ -n "$TOOLS_FILE" ] && [ -f "$TOOLS_FILE" ]; then
  TOOLS_SECTION=$(python3 - "$TOOLS_FILE" <<'PY'
import json, sys
path = sys.argv[1]
doc = json.load(open(path))
verified = [c for c in doc.get("capabilities", []) if c.get("status") == "verified"]
lines = []
for c in verified:
    label = c.get("tool") or c.get("id")
    kind = c.get("kind", "")
    server = c.get("server", "")
    if kind == "cursor-mcp" and server:
        lines.append(f"   - MCP **{server}** → **{label}** (verified {c.get('verified_at', '')})")
    elif kind == "script":
        lines.append(f"   - SAI script **{label}** (verified {c.get('verified_at', '')})")
    else:
        lines.append(f"   - **{label}** ({kind}; verified {c.get('verified_at', '')})")
if not lines:
    print("   - (no verified capabilities in tools.json — complete Phase 5B first)")
else:
    print("\n".join(lines))
PY
)
else
  TOOLS_SECTION="   - (no --tools-file provided — run scripts/agent-verify-caps first)"
fi

HOOKS_FILE="$REPO_ROOT/.ai/agents/$FOLDER_SLUG/hooks.json"
CLAUDE_RUNTIME_TRUTH=""
CLAUDE_CADENCE_LABEL="Proposed cadence"
CLAUDE_CADENCE_VALUE="${SCHEDULE} (configure only after verified mechanism)"
CLAUDE_RECURRING_SECTION=""
if [ "$SUITE" = "claude" ]; then
  eval "$(python3 - "$TOOLS_FILE" "$HOOKS_FILE" "$AGENT_NAME" "$SCHEDULE" <<'PY'
import json, os, shlex, sys

tools_path, hooks_path, agent_name, default_schedule = sys.argv[1:5]

def verified_scheduled_task(tools_path: str):
    if not tools_path or not os.path.isfile(tools_path):
        return None
    doc = json.load(open(tools_path, encoding="utf-8"))
    for cap in doc.get("capabilities", []):
        if cap.get("id") == "claude-code-scheduled-task" and cap.get("status") == "verified":
            return cap
    return None

def active_hooks_schedule(hooks_path: str):
    if not hooks_path or not os.path.isfile(hooks_path):
        return None
    doc = json.load(open(hooks_path, encoding="utf-8"))
    for trig in doc.get("automation_triggers", {}).get("required", []):
        if trig.get("type") == "scheduled" and trig.get("status") == "active":
            return trig
    return None

cap = verified_scheduled_task(tools_path)
hook = active_hooks_schedule(hooks_path)

if cap and hook:
    task_id = hook.get("task_id") or "scheduled-task"
    schedule = hook.get("schedule") or default_schedule
    caveat = hook.get("caveat") or cap.get("evidence", "")
    verified_at = cap.get("verified_at", "")
    runtime = (
        f"Claude Code CLI is {agent_name}'s primary runtime (`claude-code-cli`).\n"
        f"**Verified live automation:** Claude Code scheduled task `{task_id}` "
        f"({schedule}). Ad-hoc sessions use the same SAI protocol block below.\n"
        f"{caveat}\n"
        "Authoritative trigger truth also lives in `hooks.json`. Do not regress this "
        "profile to “session-driven until verified” while that capability stays "
        "`verified` in `runtimes/claude/tools.json`. No Cursor Automations UI step "
        "is required or valid for this suite."
    )
    cadence_label = "Verified cadence"
    cadence_value = (
        f"{schedule} — task `{task_id}` (Claude Code scheduled task, verified {verified_at})"
    )
    recurring = (
        "## Verified recurring automation\n\n"
        f"Live task `{task_id}` on schedule `{schedule}` (recorded in `hooks.json` "
        "and `runtimes/claude/tools.json` capability `claude-code-scheduled-task`). "
        "Re-run Phase 5B before changing or removing it:\n\n"
        "1. `scripts/agent-verify-caps --environment claude-code-cli "
        "--tools-file .ai/agents/<name>/runtimes/claude/tools.json`\n"
        "2. Update `hooks.json`, this profile, and the registry `automation` field "
        "together — never overwrite verified facts with the unverified template.\n"
        "3. Post `[SAI][VERIFY]` to #agentupdates (`C0BH15HDN2Z`) after the first "
        "successful scheduled run or any material change."
    )
else:
    runtime = (
        f"Claude Code CLI is {agent_name}'s primary runtime (`claude-code-cli`).\n"
        "Automation is **session-driven** until a principal verifies Claude scheduled\n"
        "tasks or MCP connectors in Phase 5B and records evidence in\n"
        "`runtimes/claude/tools.json`. No Cursor Automations UI step is required or\n"
        "valid for this suite."
    )
    recurring = (
        "## Optional recurring automation (after verification)\n\n"
        "When Claude Code exposes a verified scheduled task or MCP connector:\n\n"
        "1. Complete Phase 5B:\n"
        "   `scripts/agent-verify-caps --environment claude-code-cli \\\n"
        "     --tools-file .ai/agents/<name>/runtimes/claude/tools.json`\n"
        "2. Record the mechanism in `tools.json` with `status: verified` and\n"
        "   evidence (see Mimi `claude-code-scheduled-task` capability for format).\n"
        "3. Update this profile with the task name, cron, and first successful\n"
        "   `[SAI][VERIFY]` post to #agentupdates (`C0BH15HDN2Z`).\n"
        "4. Change the registry `automation` field from `delegated:` to the live\n"
        "   claim only after step 3.\n\n"
        "Until then, registry stays:\n"
        "`delegated: .ai/agents/<name>/runtimes/claude/automation/profile.md (...)`."
    )

print(f"CLAUDE_RUNTIME_TRUTH={shlex.quote(runtime)}")
print(f"CLAUDE_CADENCE_LABEL={shlex.quote(cadence_label)}")
print(f"CLAUDE_CADENCE_VALUE={shlex.quote(cadence_value)}")
print(f"CLAUDE_RECURRING_SECTION={shlex.quote(recurring)}")
PY
)"
fi

# Nested heredoc-in-$(...) is avoided here: bash mis-tracks quote nesting
# across the substitution boundary when the body has an odd number of
# unescaped apostrophes (this template's possessives trigger it). `read -d`
# gives identical ${VAR} expansion without the nested-substitution parse bug.
if [ "$SUITE" = "claude" ]; then
read -r -d '' SPEC <<EOF || true
# Claude Code operating profile — ${AGENT_NAME} (${AGENT_ID})

> Generated ${TODAY} by \`scripts/agent-automation-spec --suite claude\` for
> principal **${PRINCIPAL}**. This documents **Claude Code** invocation and
> session protocol — not Cursor Automations. Do not paste this into Cursor
> Automations.

## Runtime truth

${CLAUDE_RUNTIME_TRUTH}

| | |
|---|---|
| Agent name | ${AGENT_NAME} |
| Role title | ${ROLE_TITLE} |
| Agent ID | \`${AGENT_ID}\` (use \`SAI_AGENT_ID=${AGENT_ID}\` in sessions) |
| Principal | ${PRINCIPAL} |
| Repository | \`${REPO}\` (branch \`${BRANCH}\`) |
| Purpose | ${PURPOSE} |
| ${CLAUDE_CADENCE_LABEL} | ${CLAUDE_CADENCE_VALUE} |

## Invocation

1. Open \`${REPO}\` in Claude Code (repo root on disk).
2. Read \`CLAUDE.md\`, then \`.ai/agents/${FOLDER_SLUG}/AGENT.md\`, this file,
   and \`.ai/_config/reporting.yaml\`.
3. Load Layer 1 constraints manually: \`.cursor/rules/sai-coordination.mdc\`
   is Cursor-format — read it as reference; it is not auto-applied in Claude.
4. Run with \`SAI_AGENT_ID=${AGENT_ID}\` for SAI scripts and commit trailers.

Contractor/isolated worktrees: follow \`entry_points\` in
\`.ai/agents/registry.json\` for this agent (may include a child project directory).

## Session startup contract

1. Verify repository, remote, branch, worktree isolation, and file claims in
   other agents' \`.ai/runs/*/metadata.json\`.
2. Read the stage contract under \`.ai/stages/\` that matches the task.
3. Post INTAKE and PLAN (Slack or \`scripts/agent-report\` queue) before edits.
4. Run \`scripts/verify-agent-audit\`, \`scripts/verify-semantic-hierarchy\`,
   and contract-specific checks before publication.
5. Post VERIFY/HANDOFF with exact command output; never claim success without
   evidence.

${CLAUDE_RECURRING_SECTION}

## Verified capabilities (Claude Code)

Authoritative evidence: \`runtimes/claude/tools.json\`. Only \`verified\`
entries may appear in automation claims:

${TOOLS_SECTION}

## SAI protocol block (every session or verified scheduled run)

\`\`\`
You are "${AGENT_NAME}" (${ROLE_TITLE}), a Claude Code session for SAI
agent-id ${AGENT_ID}, working under principal ${PRINCIPAL} on ${REPO}.

PURPOSE (stick to it):
${PURPOSE}
If a run would take you outside this purpose, do not do the work: say so in
your report and stop. Never expand your own scope.

CONTEXT: read .ai/CONTEXT.md, CLAUDE.md, .ai/_config/reporting.yaml, and
.ai/agents/${FOLDER_SLUG}/AGENT.md. Read .cursor/rules/sai-coordination.mdc
as Layer 1 reference. Use SAI_AGENT_ID=${AGENT_ID} for SAI scripts.

SAI PROTOCOL BLOCK (identical intent to Cursor automations — do, in order):
1. git fetch origin ${BRANCH}; confirm a clean checkout of ${REPO}. If the
   repository is unreachable, post BLOCKED and stop.
2. Run scripts/agent-report flush. Report events delivered vs still queued.
3. Run scripts/verify-agent-audit origin/${BRANCH}..HEAD and
   scripts/verify-semantic-hierarchy. Capture exact output.
4. Run scripts/agent-sync-drive. Report pending/synced/failed/diverged honestly.
5. Do role-specific work per PURPOSE with artifacts in .ai/runs/<task-id>/,
   commit trailers (Task-ID, Agent, Plan, Report-Event), and remote-SHA checks
   after any push.
6. Post [SAI][VERIFY] or [SAI][BLOCKED] to #agentupdates (C0BH15HDN2Z), tagging
   ${PRINCIPAL}, using .ai/_config/reporting.yaml.
7. Never force-push, merge, close PRs, rewrite history, delete shared resources,
   touch credentials, or use SAI_AUDIT_BYPASS.
\`\`\`

## Delivery

Offer this profile to ${PRINCIPAL} via #agentupdates with invocation steps.
Do **not** instruct the principal to create Cursor Automations for Claude-primary
agents.
EOF
else
read -r -d '' SPEC <<EOF || true
# Cursor automation profile — ${AGENT_NAME} (${AGENT_ID})

> Generated ${TODAY} by \`scripts/agent-automation-spec\` for principal
> **${PRINCIPAL}**. This is the default automation profile every initialized
> SAI agent offers its principal. The **Purpose** is specific to this agent's
> role; the **SAI protocol block** in the instructions is identical for all
> agents, so every automation follows the same Slack, GitHub, and CI
> protocols.

## Identity

| | |
|---|---|
| Agent name | ${AGENT_NAME} |
| Role title | ${ROLE_TITLE} |
| Agent ID | \`${AGENT_ID}\` (automation runs as \`${AGENT_ID}-automation\`) |
| Principal | ${PRINCIPAL} |
| Purpose | ${PURPOSE} |

## Create it in Cursor (matches the Automations UI)

1. Cursor Desktop sidebar → **Automations** → new automation (opens as
   "Untitled").
2. Click **Untitled** and set the Name:
   \`SAI ${AGENT_NAME} — ${ROLE_TITLE} (${AGENT_ID})\`
3. **Select repository** → \`${REPO}\` (the \`sai\` repo).
4. **Triggers → + Add Trigger → Scheduled** → ${SCHEDULE}.
   (Optional additional triggers, principal's choice: **Slack** to run on
   mention, **GitHub** to run on PR events. Keep Scheduled as the baseline.)
5. **Agent Instructions**: paste the block below verbatim. Leave the model
   at the default shown in the dropdown, or pick your preferred model —
   the instructions are model-agnostic.
6. **Tools → + Add Tool or MCP**:
   - Slack → **Send to Slack** (required — reports go to #agentupdates)
   - Slack → **Read Public Slack Channels** (required — reads the channel
     before posting, per the reporting contract)
   - GitHub → **Comment on Pull Request** (optional — lets the automation
     leave its verification summary on the PR it checked)
   - Agent-verified capabilities (from \`tools.json\`; only list what was tested):
${TOOLS_SECTION}
   - Keep **Memories** enabled if present.
7. **Save**, toggle **Active**, then run it once manually (▷) and confirm
   its \`[SAI][VERIFY]\` message appears in #agentupdates.

## Agent Instructions (paste verbatim)

\`\`\`
You are "${AGENT_NAME}" (${ROLE_TITLE}), the scheduled Cursor automation for
SAI agent-id ${AGENT_ID}, working under principal ${PRINCIPAL} in the
coordinated SAI development system on ${REPO}.

PURPOSE (stick to it):
${PURPOSE}
If a run would take you outside this purpose, do not do the work: say so in
your report and stop. Never expand your own scope.

CONTEXT: read .ai/CONTEXT.md, then .ai/_config/reporting.yaml, then the rule
.cursor/rules/sai-coordination.mdc. They bind you like every SAI agent. Use
SAI_AGENT_ID=${AGENT_ID}-automation for anything you run.

SAI PROTOCOL BLOCK (identical for all SAI automations — do, in order):
1. git fetch origin ${BRANCH}; confirm a clean checkout of ${REPO}. If the
   repository is unreachable, post BLOCKED (step 5 format) and stop.
2. Run scripts/agent-report flush. Report events delivered vs still queued.
   Never reorder, drop, or fabricate deliveries.
3. Run scripts/verify-agent-audit origin/${BRANCH}..HEAD and
   scripts/verify-semantic-hierarchy. Capture exact output.
4. Run scripts/agent-sync-drive. Report its status
   (pending/synced/failed/diverged) honestly.
5. Do the role-specific work your PURPOSE defines, if any, following the six
   stage contracts under .ai/stages/ with artifacts in .ai/runs/<task-id>/,
   commit trailers (Task-ID, Agent, Plan, Report-Event), and remote-SHA
   verification after any push. If your purpose is reporting-only, make no
   code changes, no commits, no pushes.
6. Post one message to #agentupdates (channel C0BH15HDN2Z) using the
   [SAI][VERIFY][<YYYYMMDD-HHMM>-<purpose-slug>-${AGENT_ID}] template from
   .ai/_config/reporting.yaml, tagging ${PRINCIPAL}. If anything failed, use
   [SAI][BLOCKED][...] with the exact failing output instead.
7. Hard limits, always: never force-push, merge, close or mark PRs ready,
   rewrite history, delete shared resources, touch credentials, or use
   SAI_AUDIT_BYPASS. Human review gates in .ai/_config/security-policy.md
   are absolute.
\`\`\`

## After creating it

1. Confirm the first manual run posted \`[SAI][VERIFY]\` to #agentupdates.
2. Update \`.ai/agents/registry.json\`: set this agent's \`automation\` to
   \`"SAI ${AGENT_NAME} — ${ROLE_TITLE} (${AGENT_ID}); <schedule>; created <date>"\`
   (any agent can make this edit on a branch with proper trailers).
EOF
fi

if [ "$TO_STDOUT" = "1" ]; then
  printf '%s\n' "$SPEC"
else
  mkdir -p "$(dirname "$OUT")"
  printf '%s\n' "$SPEC" > "$OUT"
  echo "agent-automation-spec: wrote $OUT"
  echo "Next: deliver it to $PRINCIPAL via #agentupdates and set your registry"
  echo "entry's automation field to: delegated: ${OUT#"$REPO_ROOT"/}"
fi

#!/usr/bin/env bash
# verify-semantic-hierarchy — enforce the ICM (arXiv:2603.16021) semantic
# hierarchy of the .ai workspace. Run locally, from pre-push, and in CI.
#
# Usage: verify-semantic-hierarchy [repo-root]
#
# Checks (structure, not content style):
#   1. Layer files exist: .ai/CONTEXT.md, .ai/INITIALIZE.md, all six stage
#      contracts, config, schemas, charters, Cursor rule, hooks, scripts.
#   2. Stage folders are exactly the six numbered stages (order encodes the
#      pipeline; strays break routing).
#   3. Every run directory matches the task-id grammar and contains
#      metadata.json (valid JSON, task_id matching the directory name);
#      stage output dirs inside runs are limited to the six known stages
#      and keep artifacts under output/.
#   4. Stage ordering provenance: a run with 03_implement output has a plan
#      (02_plan output or an explicit plan reference in metadata.json);
#      a run with 06_publish_sync output also has 04_verify and 05_review.
#   5. events.jsonl files are valid JSON-per-line with required fields and
#      task_id consistent with their run.
#   6. Registry (.ai/agents/registry.json) is valid and every charter
#      folder it references exists.
#   7. No obvious secrets inside .ai/ (defense in depth; hooks also redact).
set -u

ROOT=${1:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}
cd "$ROOT" || { echo "verify-semantic-hierarchy: cannot cd to $ROOT" >&2; exit 2; }

python3 - <<'PY'
import json, os, re, sys, glob

fails = []
def fail(msg): fails.append(msg)

STAGES = ["01_intake", "02_plan", "03_implement", "04_verify", "05_review", "06_publish_sync"]
TASK_ID = re.compile(r"^[0-9]{8}-[0-9]{4}-[a-z0-9][a-z0-9-]*$")
VALID_RUNTIMES = {"cursor-desktop", "cursor-cloud-vm", "claude-code-cli", "codex-desktop"}
RUNTIME_SUITE = {
    "cursor-desktop": "cursor",
    "cursor-cloud-vm": "cursor",
    "claude-code-cli": "claude",
    "codex-desktop": "codex",
}
MIN_ACTIVE_VERIFIED_CAPS = 3
NON_CURSOR_RUNTIMES = {"claude-code-cli", "codex-desktop"}
CURSOR_PROFILE_MARKERS = ("Cursor Automations UI", "scheduled Cursor automation")

def load_capabilities_tools(agent_dir, manifest):
    cap_rel = manifest.get("canonical_capabilities_path")
    if cap_rel:
        cap_path = f"{agent_dir}/{cap_rel}"
        if not os.path.exists(cap_path):
            fail(f"canonical_capabilities_path missing: {cap_path}")
        try:
            return json.load(open(cap_path)), cap_path
        except (json.JSONDecodeError, UnicodeDecodeError) as e:
            fail(f"{cap_path}: invalid JSON ({e})")
            return manifest, cap_path
    return manifest, f"{agent_dir}/tools.json"

def count_verified_caps(tools_doc):
    return sum(1 for c in tools_doc.get("capabilities", []) if c.get("status") == "verified")

def agent_init_evidence(agent_id, folder=""):
    runs_root = ".ai/runs"
    if not os.path.isdir(runs_root):
        return False
    name_slug = folder.rstrip("/").split("/")[-1] if folder else ""
    init_markers = ("agent-initialization", "initialization", "ceo-activation", "initialize")
    for run in os.listdir(runs_root):
        run_path = f"{runs_root}/{run}"
        if not os.path.isdir(run_path):
            continue
        if not any(m in run for m in init_markers):
            continue
        meta_agent = None
        meta_path = f"{run_path}/metadata.json"
        if os.path.isfile(meta_path):
            try:
                meta_agent = json.load(open(meta_path)).get("agent")
            except (json.JSONDecodeError, UnicodeDecodeError):
                pass
        identity_match = (
            agent_id in run
            or (name_slug and name_slug in run)
            or meta_agent == agent_id
        )
        if not identity_match:
            continue
        handoff = f"{run_path}/handoff.md"
        if os.path.isfile(handoff) and os.path.getsize(handoff) > 20:
            return True
        ev = f"{run_path}/events.jsonl"
        if os.path.isfile(ev):
            for line in open(ev):
                line = line.strip()
                if not line:
                    continue
                try:
                    if json.loads(line).get("event_type") == "INTAKE":
                        return True
                except json.JSONDecodeError:
                    continue
    return False

def stub_suite_has_verified(agent_dir, suite):
    path = f"{agent_dir}/runtimes/{suite}/tools.json"
    if not os.path.exists(path):
        return False
    try:
        doc = json.load(open(path))
        return any(c.get("status") == "verified" for c in doc.get("capabilities", []))
    except (json.JSONDecodeError, UnicodeDecodeError):
        return False

# 1. Required layer files
required = (
    [".ai/CONTEXT.md", ".ai/INITIALIZE.md",
     ".ai/_config/repositories.yaml", ".ai/_config/reporting.yaml",
     ".ai/_config/sync-policy.md", ".ai/_config/security-policy.md",
     ".ai/shared/references/icm-ci-policy.md",
     ".ai/shared/references/agent-runtimes.md",
     ".ai/shared/schemas/stage-output.schema.json",
     ".ai/agents/registry.json",
     ".ai/runs/README.md", ".ai/audit/README.md",
     "CLAUDE.md", "CODEX.md",
     ".cursor/rules/sai-coordination.mdc",
     ".github/workflows/agent-audit.yml",
     "scripts/agent-report", "scripts/agent-init",
     "scripts/install-agent-hooks", "scripts/verify-agent-audit",
     "scripts/verify-semantic-hierarchy", "scripts/agent-sync-drive",
     "scripts/agent-scaffold", "scripts/agent-verify-caps",
     "scripts/agent-automation-spec", "scripts/verify-merge-handoff",
     "scripts/ci-merge-handoff-slack", "scripts/agent-memory-scaffold",
     "scripts/agent-contract-scaffold", "scripts/agent-contract-pr-review",
     "scripts/verify-scaffold-safety", "scripts/lib/agent-path-guards.sh"]
    + [f".ai/stages/{s}/CONTEXT.md" for s in STAGES]
    + [".githooks/" + h for h in
       ["post-checkout", "post-commit", "post-merge", "post-rewrite",
        "pre-push", "post-push-equivalent.sh"]]
)
for p in required:
    if not os.path.exists(p):
        fail(f"missing required file: {p}")

# 2. Stage folders are exactly the six known stages
if os.path.isdir(".ai/stages"):
    actual = sorted(d for d in os.listdir(".ai/stages") if os.path.isdir(f".ai/stages/{d}"))
    if actual != STAGES:
        fail(f".ai/stages must contain exactly {STAGES}, found {actual}")

# 3 + 4 + 5. Runs
if os.path.isdir(".ai/runs"):
    for run in sorted(os.listdir(".ai/runs")):
        path = f".ai/runs/{run}"
        if not os.path.isdir(path):
            if run != "README.md":
                fail(f"unexpected file in .ai/runs: {run}")
            continue
        if not TASK_ID.match(run):
            fail(f"run directory '{run}' does not match task-id grammar YYYYMMDD-HHMM-<purpose>-<agent-id>")
            continue
        meta_path = f"{path}/metadata.json"
        meta = None
        if not os.path.exists(meta_path):
            fail(f"{run}: missing metadata.json")
        else:
            try:
                meta = json.load(open(meta_path))
                if meta.get("task_id") != run:
                    fail(f"{run}: metadata.json task_id '{meta.get('task_id')}' != directory name")
                for key in ("agent", "repository", "status"):
                    if not meta.get(key):
                        fail(f"{run}: metadata.json missing required field '{key}'")
            except (json.JSONDecodeError, UnicodeDecodeError) as e:
                fail(f"{run}: metadata.json invalid JSON ({e})")
        present = set()
        for entry in os.listdir(path):
            full = f"{path}/{entry}"
            if os.path.isdir(full):
                if entry not in STAGES:
                    fail(f"{run}: unknown stage directory '{entry}' (allowed: {STAGES})")
                else:
                    present.add(entry)
                    inner = os.listdir(full)
                    if inner != ["output"] and set(inner) - {"output"}:
                        fail(f"{run}/{entry}: stage artifacts must live under output/, found {sorted(set(inner) - {'output'})}")
            elif entry not in ("metadata.json", "events.jsonl", "handoff.md"):
                fail(f"{run}: unexpected top-level file '{entry}' (allowed: metadata.json, events.jsonl, handoff.md, stage dirs)")
        # stage-order provenance
        has_plan = "02_plan" in present or (meta or {}).get("plan_reference")
        if "03_implement" in present and not has_plan:
            fail(f"{run}: has 03_implement output but no 02_plan output or metadata plan_reference")
        if "06_publish_sync" in present:
            for req in ("04_verify", "05_review"):
                if req not in present:
                    fail(f"{run}: has 06_publish_sync output but missing {req}")
        # events.jsonl
        ev = f"{path}/events.jsonl"
        if os.path.exists(ev):
            for i, line in enumerate(open(ev), 1):
                line = line.strip()
                if not line:
                    continue
                try:
                    d = json.loads(line)
                except json.JSONDecodeError as e:
                    fail(f"{run}: events.jsonl line {i} invalid JSON ({e})")
                    continue
                for key in ("event_id", "event_type", "task_id", "actor", "timestamp"):
                    if key not in d:
                        fail(f"{run}: events.jsonl line {i} missing '{key}'")
                if d.get("task_id") != run:
                    fail(f"{run}: events.jsonl line {i} task_id '{d.get('task_id')}' != run")

# 6. Registry
if os.path.exists(".ai/agents/registry.json"):
    try:
        reg = json.load(open(".ai/agents/registry.json"))
        agents = reg.get("agents", [])
        seen_ids, seen_folders, seen_names = {}, {}, {}
        ceo_active = 0
        for i, a in enumerate(agents):
            for key in ("agent_id", "charter", "principal", "status"):
                if not a.get(key):
                    fail(f"registry agent[{i}]: missing '{key}'")
            charter = a.get("charter", "")
            if charter and not os.path.exists(charter):
                fail(f"registry agent[{i}]: charter path does not exist: {charter}")
            if a.get("status") not in ("active", "provisional", "retired", None):
                fail(f"registry agent[{i}]: status must be active|provisional|retired")
            if a.get("status") == "active":
                for key in ("name", "role_title", "purpose"):
                    if not a.get(key):
                        fail(f"registry agent[{i}]: active agents must have '{key}' (granted/confirmed by the principal in Phase 5)")
                pr = a.get("primary_runtime")
                if not pr:
                    fail(f"registry agent[{i}]: active agents must have primary_runtime")
                elif pr not in VALID_RUNTIMES:
                    fail(f"registry agent[{i}]: primary_runtime '{pr}' not in {sorted(VALID_RUNTIMES)}")
                eps = a.get("entry_points")
                if not isinstance(eps, dict) or not eps:
                    fail(f"registry agent[{i}]: active agents must have entry_points map")
            auto = a.get("automation") or ""
            if a.get("status") in ("active", "provisional"):
                if not auto:
                    fail(f"registry agent[{i}]: automation field required (real automation or 'delegated: <spec path>')")
                elif auto.startswith("unavailable"):
                    fail(f"registry agent[{i}]: automation 'unavailable' is not allowed — use scripts/agent-automation-spec and record 'delegated: <spec path>' (Phase 6 Path B)")
                elif auto.startswith("delegated:"):
                    spec = auto.split("delegated:", 1)[1].strip().split(" ")[0]
                    if not os.path.exists(spec):
                        fail(f"registry agent[{i}]: delegated automation spec does not exist: {spec}")
            # Agent folder (Phase 6): provisional agents use agent-id; active use granted name
            folder = a.get("folder")
            if a.get("status") in ("active", "provisional"):
                if not folder:
                    fail(f"registry agent[{i}]: missing 'folder' (e.g. .ai/agents/<name>/)")
                elif not folder.startswith(".ai/agents/"):
                    fail(f"registry agent[{i}]: folder must be under .ai/agents/: {folder}")
                else:
                    agent_dir = folder.rstrip("/")
                    required_agent_files = [
                        "AGENT.md", "skills.md", "tools.json", "hooks.json",
                        "automation/profile.md",
                    ]
                    for af in required_agent_files:
                        fp = f"{agent_dir}/{af}"
                        if not os.path.exists(fp):
                            fail(f"registry agent[{i}]: agent folder missing {af} at {fp}")
                    rt_readme = f"{agent_dir}/runtimes/README.md"
                    if not os.path.exists(rt_readme):
                        fail(f"registry agent[{i}]: missing runtimes/README.md")
                    if a.get("status") == "active" and a.get("primary_runtime"):
                        suite = RUNTIME_SUITE.get(a["primary_runtime"])
                        if suite:
                            suite_tools = f"{agent_dir}/runtimes/{suite}/tools.json"
                            if not os.path.exists(suite_tools):
                                fail(f"registry agent[{i}]: missing primary runtime tools at {suite_tools}")
                    # tools.json manifest + canonical capabilities evidence
                    try:
                        manifest = json.load(open(f"{agent_dir}/tools.json"))
                        tools, tools_path = load_capabilities_tools(agent_dir, manifest)
                        for j, cap in enumerate(tools.get("capabilities", [])):
                            if cap.get("status") == "verified" and not cap.get("evidence"):
                                fail(f"registry agent[{i}]: {tools_path} capability[{j}] marked verified without evidence")
                        tf = tools.get("folder", manifest.get("folder", ""))
                        if tf and tf != agent_dir:
                            fail(f"registry agent[{i}]: tools folder '{tf}' != registry folder '{agent_dir}'")
                        cap_rel = manifest.get("canonical_capabilities_path")
                        if a.get("status") == "active":
                            if not cap_rel:
                                fail(f"registry agent[{i}]: active agents must have canonical_capabilities_path in tools.json manifest")
                            pr_reg = a.get("primary_runtime")
                            pr_man = manifest.get("primary_runtime")
                            if pr_man and pr_reg and pr_man != pr_reg:
                                fail(f"registry agent[{i}]: tools.json primary_runtime '{pr_man}' != registry '{pr_reg}'")
                        if cap_rel and a.get("status") == "active":
                            pr = a.get("primary_runtime")
                            suite = RUNTIME_SUITE.get(pr or "")
                            if suite and not cap_rel.startswith(f"runtimes/{suite}/"):
                                fail(f"registry agent[{i}]: canonical_capabilities_path '{cap_rel}' does not match primary_runtime suite '{suite}'")
                            verified_count = count_verified_caps(tools)
                            if verified_count < MIN_ACTIVE_VERIFIED_CAPS:
                                fail(f"registry agent[{i}]: active agent has {verified_count} verified capabilities in {tools_path}; minimum {MIN_ACTIVE_VERIFIED_CAPS} required (complete INITIALIZE Phase 5B)")
                        # Non-primary runtime suites must not claim verified capabilities
                        pr_reg = a.get("primary_runtime")
                        primary_suite = RUNTIME_SUITE.get(pr_reg or "")
                        for suite in ("cursor", "claude", "codex"):
                            if suite == primary_suite:
                                continue
                            if stub_suite_has_verified(agent_dir, suite):
                                fail(f"registry agent[{i}]: runtimes/{suite}/tools.json has verified capabilities but primary_runtime is '{pr_reg}' (stub until live init in that runtime)")
                        # Codex stub: non-codex-primary agents must not claim verified Codex caps
                        codex_tools = f"{agent_dir}/runtimes/codex/tools.json"
                        if os.path.exists(codex_tools):
                            try:
                                cdoc = json.load(open(codex_tools))
                                if a.get("primary_runtime") != "codex-desktop":
                                    for j, cap in enumerate(cdoc.get("capabilities", [])):
                                        if cap.get("status") == "verified":
                                            fail(f"registry agent[{i}]: runtimes/codex/tools.json has verified capability[{j}] but agent primary_runtime is not codex-desktop (stub until live init)")
                            except (json.JSONDecodeError, UnicodeDecodeError) as e:
                                fail(f"registry agent[{i}]: runtimes/codex/tools.json invalid JSON ({e})")
                    except (json.JSONDecodeError, UnicodeDecodeError) as e:
                        fail(f"registry agent[{i}]: tools.json invalid JSON ({e})")
                    try:
                        json.load(open(f"{agent_dir}/hooks.json"))
                    except (json.JSONDecodeError, UnicodeDecodeError) as e:
                        fail(f"registry agent[{i}]: hooks.json invalid JSON ({e})")
                    if a.get("status") == "active":
                        aid = a.get("agent_id", "")
                        if not agent_init_evidence(aid, folder or ""):
                            fail(f"registry agent[{i}]: active agent '{aid}' lacks Phase 9 initialization evidence (.ai/runs/*initialization* with handoff.md or INTAKE event)")
                        pr = a.get("primary_runtime")
                        if pr in NON_CURSOR_RUNTIMES:
                            suite = RUNTIME_SUITE.get(pr or "")
                            profile = f"{agent_dir}/runtimes/{suite}/automation/profile.md"
                            if os.path.isfile(profile):
                                text = open(profile, encoding="utf-8", errors="ignore").read()
                                if any(marker in text for marker in CURSOR_PROFILE_MARKERS):
                                    fail(f"registry agent[{i}]: {profile} contains Cursor Automations UI content but primary_runtime is '{pr}' — use runtime-native profile (INITIALIZE Phase 7)")
            # Uniqueness: no duplicate agent_id, folder, or active name
            if a.get("status") != "retired":
                aid = a.get("agent_id")
                if aid in seen_ids:
                    fail(f"registry: duplicate agent_id '{aid}' (agents {seen_ids[aid]} and {i})")
                seen_ids[aid] = i
                if folder:
                    fd = folder.rstrip("/")
                    if fd in seen_folders:
                        fail(f"registry: duplicate folder '{fd}' (agents {seen_folders[fd]} and {i})")
                    seen_folders[fd] = i
                nm = a.get("name")
                if nm and a.get("status") == "active":
                    if nm in seen_names:
                        fail(f"registry: duplicate active name '{nm}' (agents {seen_names[nm]} and {i})")
                    seen_names[nm] = i
                if a.get("status") == "active" and a.get("charter", "").endswith("_roles/ceo/CHARTER.md"):
                    ceo_active += 1
        if ceo_active > 1:
            fail(f"registry: only one active CEO agent allowed, found {ceo_active}")
    except (json.JSONDecodeError, UnicodeDecodeError) as e:
        fail(f".ai/agents/registry.json invalid JSON ({e})")

# 7. Secret patterns inside .ai (values, not variable names)
secret_pat = re.compile(r"xox[baprs]-[A-Za-z0-9-]{10,}|gh[pousr]_[A-Za-z0-9]{20,}|github_pat_[A-Za-z0-9_]{20,}|AKIA[A-Z0-9]{16}|-----BEGIN [A-Z ]*PRIVATE KEY-----")
for f in glob.glob(".ai/**/*", recursive=True):
    if os.path.isfile(f):
        try:
            text = open(f, encoding="utf-8", errors="ignore").read()
        except OSError:
            continue
        m = secret_pat.search(text)
        if m:
            fail(f"possible secret in {f}: pattern '{m.group()[:12]}...'")

if fails:
    for m in fails:
        print(f"FAIL {m}", file=sys.stderr)
    print(f"verify-semantic-hierarchy: FAILED ({len(fails)} problem(s))", file=sys.stderr)
    sys.exit(1)
print("verify-semantic-hierarchy: OK")
PY

{
  "$schema": "openclaw-dashboard-design-tokens-v1",
  "meta": {
    "name": "SAI Dashboard — Cursor/Obsidian unified language",
    "platforms": ["macos-desktop", "ios-companion"],
    "reference": "Cursor Desktop + Obsidian dark UI patterns (not proprietary assets)"
  },
  "color": {
    "bg": {
      "base": "#1e1e1e",
      "elevated": "#252526",
      "surface": "#2d2d2d",
      "overlay": "#3c3c3c",
      "input": "#3c3c3c"
    },
    "border": {
      "subtle": "#3c3c3c",
      "default": "#454545",
      "focus": "#007acc"
    },
    "text": {
      "primary": "#cccccc",
      "secondary": "#969696",
      "muted": "#6e6e6e",
      "inverse": "#1e1e1e",
      "link": "#3794ff",
      "danger": "#f48771",
      "success": "#89d185",
      "warning": "#cca700"
    },
    "accent": {
      "primary": "#007acc",
      "primaryHover": "#1a8ad4",
      "secondary": "#68217a",
      "graphUp": "#89d185",
      "graphDown": "#f48771",
      "graphNeutral": "#569cd6"
    },
    "tab": {
      "activeBg": "#1e1e1e",
      "inactiveBg": "#2d2d2d",
      "activeBorder": "#007acc",
      "badge": "#007acc"
    },
    "graph": {
      "grid": "#333333",
      "crosshair": "#758595",
      "volume": "#4ec9b0"
    }
  },
  "typography": {
    "fontFamily": {
      "ui": "-apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Segoe UI', system-ui, sans-serif",
      "mono": "'SF Mono', Menlo, Monaco, 'Cascadia Code', monospace",
      "editor": "'SF Pro Text', -apple-system, sans-serif"
    },
    "fontSize": {
      "xs": "11px",
      "sm": "12px",
      "base": "13px",
      "md": "14px",
      "lg": "16px",
      "xl": "20px"
    },
    "lineHeight": {
      "tight": "1.25",
      "normal": "1.5",
      "relaxed": "1.65"
    },
    "weight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600
    }
  },
  "spacing": {
    "unit": 4,
    "tabHeight": 35,
    "sidebarWidth": 260,
    "activityBarWidth": 48,
    "statusBarHeight": 22,
    "panelPadding": 12,
    "radius": {
      "sm": "4px",
      "md": "6px",
      "lg": "8px"
    }
  },
  "motion": {
    "durationFast": "120ms",
    "durationNormal": "200ms",
    "durationSlow": "320ms",
    "easing": "cubic-bezier(0.4, 0, 0.2, 1)"
  },
  "components": {
    "button": {
      "height": 28,
      "paddingX": 12,
      "primaryBg": "#007acc",
      "primaryText": "#ffffff",
      "secondaryBg": "#3c3c3c",
      "ghostHover": "#2a2d2e"
    },
    "input": {
      "height": 28,
      "border": "#3c3c3c",
      "focusRing": "#007acc"
    },
    "tab": {
      "height": 35,
      "fontSize": "13px",
      "iconSize": 16
    },
    "graph": {
      "axisLabelSize": "11px",
      "tooltipBg": "#252526",
      "livePulseMs": 15
    }
  },
  "layout": {
    "shell": "cursor-clone",
    "regions": ["activityBar", "sidebar", "editor", "panel", "statusBar"],
    "obsidianPanels": ["graph", "backlinks", "outline"]
  }
}

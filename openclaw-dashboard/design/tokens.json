{
  "$schema": "openclaw-dashboard-design-tokens-v2",
  "meta": {
    "name": "SAI Dashboard — unified Cursor + Activity Monitor + Robinhood",
    "platforms": ["macos-desktop", "ios-companion"],
    "reference": "Cursor Desktop shell, Activity Monitor density, Robinhood live metrics, Notion block UX — not proprietary assets",
    "liveDataHost": "vps-openclaw-gateway"
  },
  "color": {
    "bg": {
      "base": "#1e1e1e",
      "elevated": "#252526",
      "surface": "#2d2d2d",
      "overlay": "#3c3c3c",
      "input": "#3c3c3c",
      "rowHover": "#2a2d2e",
      "rowStripe": "#232323"
    },
    "border": {
      "subtle": "#3c3c3c",
      "default": "#454545",
      "focus": "#007acc",
      "divider": "#333333"
    },
    "text": {
      "primary": "#cccccc",
      "secondary": "#969696",
      "muted": "#6e6e6e",
      "inverse": "#1e1e1e",
      "link": "#3794ff",
      "danger": "#f48771",
      "success": "#89d185",
      "warning": "#cca700"
    },
    "accent": {
      "primary": "#007acc",
      "primaryHover": "#1a8ad4",
      "secondary": "#68217a",
      "graphUp": "#89d185",
      "graphDown": "#f48771",
      "graphNeutral": "#569cd6"
    },
    "tab": {
      "activeBg": "#1e1e1e",
      "inactiveBg": "#2d2d2d",
      "activeBorder": "#007acc",
      "badge": "#007acc"
    },
    "graph": {
      "grid": "#333333",
      "crosshair": "#758595",
      "volume": "#4ec9b0",
      "livePulse": "#007acc"
    },
    "activityMonitor": {
      "barBg": "#3c3c3c",
      "barFill": "#007acc",
      "barWarn": "#cca700",
      "barCritical": "#f48771",
      "headerBg": "#252526"
    },
    "robinhood": {
      "metricUp": "#00c805",
      "metricDown": "#ff5000",
      "sparklineUp": "#89d185",
      "sparklineDown": "#f48771"
    },
    "game": {
      "hudBg": "rgba(30, 30, 30, 0.85)",
      "hudBorder": "#3c3c3c",
      "chatBubbleAgent": "#252526",
      "chatBubbleUser": "#007acc"
    }
  },
  "typography": {
    "fontFamily": {
      "ui": "-apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Segoe UI', system-ui, sans-serif",
      "mono": "'SF Mono', Menlo, Monaco, 'Cascadia Code', monospace",
      "editor": "'SF Pro Text', -apple-system, sans-serif",
      "metric": "-apple-system, BlinkMacSystemFont, 'SF Pro Display', system-ui, sans-serif"
    },
    "fontSize": {
      "xs": "11px",
      "sm": "12px",
      "base": "13px",
      "md": "14px",
      "lg": "16px",
      "xl": "20px",
      "metricHero": "28px"
    },
    "lineHeight": {
      "tight": "1.25",
      "normal": "1.5",
      "relaxed": "1.65",
      "metric": "1.1"
    },
    "weight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600
    }
  },
  "spacing": {
    "unit": 4,
    "tabHeight": 35,
    "sidebarWidth": 260,
    "activityBarWidth": 48,
    "statusBarHeight": 22,
    "panelPadding": 12,
    "blockGap": 8,
    "toolbarGap": 8,
    "dropdownItemPad": 4,
    "radius": {
      "sm": "4px",
      "md": "6px",
      "lg": "8px"
    }
  },
  "motion": {
    "durationInstant": "80ms",
    "durationFast": "120ms",
    "durationNormal": "200ms",
    "durationSlow": "320ms",
    "durationMetric": "400ms",
    "durationShimmer": "1200ms",
    "easing": "cubic-bezier(0.4, 0, 0.2, 1)",
    "easingSpring": "cubic-bezier(0.34, 1.56, 0.64, 1)",
    "pressScale": 0.98,
    "focusRingWidth": "2px",
    "focusRingOffset": "1px"
  },
  "elevation": {
    "menu": "0 4px 16px rgba(0, 0, 0, 0.45)",
    "panel": "0 2px 8px rgba(0, 0, 0, 0.35)",
    "hud": "0 4px 24px rgba(0, 0, 0, 0.5)"
  },
  "components": {
    "button": {
      "height": 28,
      "paddingX": 12,
      "iconSize": 16,
      "gap": 8,
      "primaryBg": "#007acc",
      "primaryText": "#ffffff",
      "secondaryBg": "#3c3c3c",
      "ghostHover": "#2a2d2e"
    },
    "input": {
      "height": 28,
      "paddingX": 8,
      "border": "#3c3c3c",
      "focusRing": "#007acc"
    },
    "select": {
      "height": 28,
      "paddingX": 8,
      "chevronSize": 12,
      "menuMaxHeight": 320,
      "menuRadius": "6px",
      "itemHeight": 28
    },
    "tab": {
      "height": 35,
      "fontSize": "13px",
      "iconSize": 16,
      "activeBorderWidth": 2
    },
    "table": {
      "rowHeight": 28,
      "headerHeight": 32,
      "fontSize": "13px",
      "monoColumnSize": "11px"
    },
    "graph": {
      "axisLabelSize": "11px",
      "tooltipBg": "#252526",
      "livePulseMs": 15
    },
    "metricHero": {
      "fontSize": "28px",
      "deltaFontSize": "13px",
      "countUpMs": 400
    },
    "rolodex": {
      "rowHeight": 28,
      "statusDot": 6,
      "nameSize": "13px",
      "ageSize": "11px"
    },
    "game": {
      "immersiveMinChromeHeight": 35,
      "hudPanelWidth": 280,
      "chatOverlayMaxHeight": "40vh"
    }
  },
  "layout": {
    "defaultMode": "shell",
    "modes": {
      "shell": {
        "regions": ["activityBar", "sidebar", "editor", "panel", "statusBar"]
      },
      "immersive-game": {
        "regions": ["activityBar", "gameViewport", "hudOverlays", "statusBar"],
        "appliesTo": ["tabs/chat-room"],
        "sidebarDefault": "collapsed"
      }
    },
    "obsidianPanels": ["graph", "backlinks", "outline"]
  },
  "liveData": {
    "reconnectIntervalMs": 5000,
    "ingestWebSocket": "/ingest/stream",
    "presenceWebSocket": "/presence/stream",
    "staleThresholdMs": 30000,
    "badgeReconnecting": "Reconnecting…"
  }
}
